      ]
    },
    "SupportedEngineVersions": {
      "allOf": [
        {
          "$ref": "#/components/schemas/__listOf__string"
        },
        {
          "xml": {
            "name": "supportedEngineVersions"
          },
          "description": "The list of supported engine versions."
        }
      ]
